# Kiln configuration. Schema: docs/SPEC.md §10.
#
# Every value shown for [server], [memory], and [defaults] is also the built-in
# default — omit any key (or the whole file section) to get it.
#
# Any scalar key can be overridden via environment variables prefixed KILN_,
# with `__` separating nesting levels:
#   KILN_SERVER__PORT=9090
#   KILN_MEMORY__BUDGET_FRACTION=0.7
#   KILN_DEFAULTS__SSD_TIER=false
# Only the server/memory/defaults/auth sections are env-addressable; [[model]]
# entries come from the file. Unrelated KILN_* variables (e.g. KILN_TEST_MODELS)
# are ignored.

[server]
host = "127.0.0.1"
port = 8080
runtime_dir = "~/.kiln/run"
cache_dir = "~/.kiln/cache"
model_dir = "~/.kiln/models"
# Command prefix used to launch the Python worker; the gateway appends
# `--model <path> --socket <path> --model-id <id>`. The default assumes the
# gateway runs from a Kiln checkout.
python_worker_argv = ["uv", "run", "--project", "python/kiln_worker_py", "python", "-m", "kiln_worker_py"]

[memory]
# Fraction of unified memory the gateway may hand out across all workers.
# The machine budget (SPEC §2.3) is total unified memory × this fraction;
# every worker's heartbeat-measured footprint (max(MLX active, weights +
# KV pool) + MLX cache) is charged against it. A load that would exceed
# the budget first evicts the least-recently-used model that is unpinned
# and outside its TTL keep-alive lease (Drain → SIGTERM → SIGKILL after
# grace); with no evictable model the load is rejected and retried on the
# next request for it.
budget_fraction = 0.80
# Explicit budget in bytes; overrides budget_fraction when set.
#budget_bytes = 25000000000

[defaults]
max_batch_tokens = 8192
prefill_chunk = 2048
block_size = 32          # tokens per KV block; must be a power of two
ssd_cache_max_gb = 64
ssd_tier = true
# Block-table-aware paged-attention Metal kernel for decode steps (SPEC
# §7.4, rust workers only). Opt-in: leave off unless the kernel's parity
# and throughput bars are proven for your device (docs/decisions/, Phase 7).
paged_attention_kernel = false

# One [[model]] block per servable model.
[[model]]
id = "qwen3-14b-4bit"
path = "mlx-community/Qwen3-14B-4bit" # HF repo id or local path
worker = "auto"                       # rust | python | auto (rust if arch + quant format supported, else python)
pinned = true                         # never evicted under memory pressure
# Idle keep-alive lease in seconds; 0 = resident forever. A model idle past
# its ttl auto-unloads (memory returns to the machine budget) and reloads on
# the next request for it; within the lease it is also protected from LRU
# eviction. Requests in flight always hold the lease open.
ttl_seconds = 0

# Optional per-model speculative decoding (SPEC §6.5; rust workers only —
# a speculative block on a python-routed model is a startup error).
#
# Correctness is unconditional: on any pair the worker agrees to serve,
# greedy output is bit-identical with speculation on or off. The worker
# refuses to start (UNHEALTHY) on a draft with an incompatible tokenizer
# or a target outside the certified verify-kernel envelope, and clamps
# gamma to that envelope (docs/decisions/0005). At runtime, speculation
# stands down automatically per-request under wide batches or sustained
# low acceptance.
#
# THROUGHPUT PRECONDITION (docs/decisions/0006): speculation only pays off
# when the draft is much smaller than the target — roughly a <=1B draft
# proposing for a >=7-8B target. On pairs of similar size it is a measured
# LOSS regardless of the acceptance rate you observe (0.63-0.71x at sub-1B
# scale: each round spends gamma draft forwards plus a verify forward, and
# at a draft/target weight ratio near 0.65 that costs more than the plain
# decode steps it replaces). Enable it for a small-drafts-large shape;
# expect a slowdown, not a gain, on anything else.
[model.speculative]
draft = "mlx-community/Qwen3-0.6B-4bit" # HF repo id or local path; tokenizer must match the target's
gamma = 4                               # tokens proposed per round (clamped per ADR 0005)

[auth]
# argon2 hash of the admin bearer token — never the raw token.
admin_token_hash = ""

[[auth.api_keys]]
name = "example"
key_hash = ""  # argon2 hash of the API key
rpm = 600      # requests/minute
tpm = 500000   # tokens/minute
